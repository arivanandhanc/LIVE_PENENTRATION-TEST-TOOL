# Copy to .env and adjust for your deployment.

# HTTP server
PORT=3000
HOST=0.0.0.0

# Where scan results are persisted (JSON files)
DATA_DIR=data

# SAFETY: keep false on the public host. Blocks scanning of loopback/private
# (SSRF protection). Set true ONLY on a trusted self-hosted instance for testing
# internal/dev apps.
ALLOW_PRIVATE=false

# Network timeouts (ms) and port-scan concurrency
HTTP_TIMEOUT=12000
TCP_TIMEOUT=2500
PORT_CONCURRENCY=60

# Scanner identity (good practice for authorised testing)
SCANNER_UA=PenTestTool/1.0 (+https://pentest.arivanandhan.in; authorised-scanning-only)

# Report branding
BRAND_COMPANY=Arivanandhan
BRAND_PRODUCT=Security Assessment
